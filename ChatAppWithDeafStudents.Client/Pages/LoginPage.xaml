<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ChatAppWithDeafStudents.Client.Pages.LoginPage"
             xmlns:viewModel="clr-namespace:ChatAppWithDeafStudents.Client.ViewModel"
             Title="LoginPage"
             Background="#13232f">
    <Grid>
        <VerticalStackLayout Margin="30" VerticalOptions="Center" >
            <Label
                FontSize="45"
                HorizontalOptions="Center"
                Text="Login"
                TextColor="White"/>
            <Border  
                Margin="0,45,0,0"
                Padding="0,0,10,0"    
                BackgroundColor="White">
                <Entry
                    Placeholder="Username"
                    ReturnType="Go"
                    TextColor="Black" 
                    Text="{Binding Email}"/>
            </Border>

            <Border 
                Margin="0,10,0,0"
                Padding="0,0,10,0"    
                BackgroundColor="White">
                <Entry
                    IsPassword="True"
                    Placeholder="Password"
                    ReturnType="Go"
                    TextColor="Black" 
                    Text="{Binding Password}"/>
            </Border>

            <Button 
                Margin="0,30,0,0"
                Text="Login" 
                TextColor="Black"
                Background="Orange"
                Command="{Binding LoginCommand}"/>
        
        </VerticalStackLayout>
    </Grid>
</ContentPage>