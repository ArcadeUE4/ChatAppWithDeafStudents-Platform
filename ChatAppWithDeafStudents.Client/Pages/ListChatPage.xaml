<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ChatAppWithDeafStudents.Client.Pages.ListChatPage"
             xmlns:viewModel="clr-namespace:ChatAppWithDeafStudents.Client.ViewModel"
             xmlns:converters="clr-namespace:ChatAppWithDeafStudents.Client.Converters"
             Title="Chats"
             Background="#13232f">

    <ContentPage.Resources>
        <converters:EmptyTextConverter x:Key="EmptyTextConverter" />
    </ContentPage.Resources>

    <RefreshView Margin="0"
        Command="{Binding RefreshCommand}"
        IsRefreshing="{Binding IsRefreshing}">
        <Grid RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- User Header -->
            <StackLayout Padding="15,15,15,10" Spacing="0">
                <Label FontAttributes="Bold" 
                       FontSize="20" 
                       Text="{Binding UserInfo.FullName}" 
                       TextColor="White"/>
            </StackLayout>

            <!-- Chat list -->
            <CollectionView Grid.Row="1"
                x:Name="ChatsCollectionView"
                ItemsSource="{Binding UserChats}"
                SelectionMode="Single"
                SelectionChangedCommand="{Binding OpenPageCommand}"
                SelectionChangedCommandParameter="{Binding SelectedItem.ChatId, Source={x:Reference ChatsCollectionView}}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <StackLayout Padding="0" Spacing="0" Margin="0">
                            
                            <Grid Padding="15,15" 
                                  RowSpacing="5"
                                  ColumnSpacing="10"
                                  BackgroundColor="#13232f"
                                  MinimumHeightRequest="70">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                
                                <Label Grid.Row="0"
                                       Grid.Column="0"
                                       FontSize="16" 
                                       FontAttributes="Bold"
                                       Text="{Binding Chat.Title}" 
                                       TextColor="White"
                                       LineBreakMode="TailTruncation" />

                                
                                <Label Grid.Row="0"
                                       Grid.Column="1"
                                       FontSize="12"
                                       Text="{Binding LastestMessage.SendDateTime, 
                                    StringFormat='{0:HH:mm}'}"
                                       TextColor="#7CB9E8"
                                       VerticalOptions="Start"
                                       HorizontalOptions="End"
                                       Margin="10,0,0,0" />

                                
                                <Label Grid.Row="1"
                                       Grid.Column="0"
                                       Grid.ColumnSpan="2"
                                       FontSize="14" 
                                       LineBreakMode="TailTruncation"
                                       Text="{Binding LastestMessage.Content, 
                                    Converter={StaticResource EmptyTextConverter}}" 
                                       TextColor="#CCCCCC" />
                            </Grid>


                            <BoxView HeightRequest="1" 
                                     BackgroundColor="#2a3f4d" 
                                     Margin="0,0,0,0" />
                        </StackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </RefreshView>
</ContentPage>